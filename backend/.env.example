# Plantilla de variables de entorno para La Rota Justa - Backend
# Copia este archivo a .env y reemplaza los valores según tu entorno
# NUNCA comitees .env con valores reales

# --- Server ---
PORT=3000

# --- PostgreSQL ---
# Formato: postgres://usuario:contraseña@host:puerto/base_datos
# Ejemplo local: postgres://rotajusta:password@localhost:5432/rotajusta_dev
DATABASE_URL=postgres://user:password@localhost:5432/rotajusta_dev

# --- CORS ---
# URL del frontend React (por defecto Vite en desarrollo)
CORS_ORIGIN=http://localhost:5173

# --- JWT (Fase 2b) ---
# Clave secreta para firmar tokens JWT (genera una cadena aleatoria larga)
# Ejemplo: openssl rand -base64 32
JWT_SECRET=tu_secreto_jwt_super_seguro_aqui

# --- JWT Token Expiry ---
# Tiempo de expiración de los tokens (ej: 1h, 7d, 30d)
JWT_EXPIRES_IN=1h

# --- Environment ---
# Valores: development, staging, production
NODE_ENV=development
